@page "/unrestaurante/{documentName}"
@using Json01.Modelos
@inject Servicios.RestauranteService servicio

<h1>Detalles del restaurante</h1>
<a href="/counter">Volver</a>

@if(restaurante is null)
{
    <p>No encontrado</p>
} else
{
    <p><strong>@restaurante?.address</strong></p>
    <p>Accesibilidad: @restaurante?.locality</p>
    <a href="@restaurante?.web" target="_blank" class="btn btn-outline-secondary btn-sm me-3">Abrir pag web</a>
    <br />
    <button class="btn btn-success" @onclick="() => AbrirMapa1(restaurante?.address)">
        Abrir Mapa con Dirección
    </button>
}

@code {
    [Parameter]
    public string? documentName { get; set; }

    public Restaurante? restaurante;

    protected override void OnParametersSet()
    {
        restaurante = servicio.restaurantes?.FirstOrDefault(x => x.documentName == documentName);
        //coge de la lista de restaurantes el primero que coincida con el parametro pasado
    }

    public async Task AbrirMapa1(string? direccion)
    {
        if (!string.IsNullOrEmpty(direccion))
        {
            string baseUrl = "https://www.google.com/maps/search/";
            string url = $"{baseUrl}{Uri.EscapeDataString(direccion)}";
            try
            {
                await Launcher.Default.OpenAsync(url);
            }
            catch (Exception ex)
            {
                await Shell.Current.DisplayAlert("Error", $"No se pudo abrir el mapa: {ex.Message}", "OK");
            }
        }
    }

}
